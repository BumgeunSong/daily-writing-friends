# Production E2E Test Configuration
# Copy to config/.env.prod.e2e and fill in real values (gitignored)

# Explicit environment flag — REQUIRED for production detection
E2E_ENV=production

# Production Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# E2E test user (pre-created via seed script)
E2E_USER_EMAIL=e2e-test@yourdomain.com
E2E_USER_PASSWORD=a-strong-random-password
E2E_ADMIN_EMAIL=e2e-admin@yourdomain.com
E2E_ADMIN_PASSWORD=a-strong-random-password

# Production app URL
BASE_URL=https://your-production-url.com
