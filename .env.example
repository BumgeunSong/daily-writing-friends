# ===========================================
# Firebase (client-side, used by web + admin)
# ===========================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MESSAGING_VAPID_KEY=your_vapid_key
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Next.js aliases (admin app reads NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# Firebase Admin SDK (server-side, admin app)
# ===========================================
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_CLOUD_FUNCTIONS_URL=https://us-central1-your_project_id.cloudfunctions.net

# ===========================================
# Supabase
# ===========================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Vite aliases (web app reads VITE_ prefix)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Next.js aliases (admin app reads NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# ===========================================
# Sentry (optional)
# ===========================================
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_READ_TOKEN=your_sentry_read_token_here

# ===========================================
# AI API Keys (admin app)
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# E2E Testing
# ===========================================
# E2E_ENV=production
# BASE_URL=https://dailywritingfriends.com
# E2E_USER_EMAIL=e2e@example.com
# E2E_USER_PASSWORD=your_test_password
# E2E_SECOND_EMAIL=e2e2@example.com
# E2E_SECOND_PASSWORD=your_test_password
# E2E_ADMIN_EMAIL=e2e-admin@example.com
# E2E_ADMIN_PASSWORD=your_admin_test_password

# ===========================================
# Misc
# ===========================================
USE_FIREBASE_EMULATOR=false
SONAR_TOKEN=your_sonar_token_here
