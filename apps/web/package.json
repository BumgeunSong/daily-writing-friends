{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode local-supabase --port 5174",
    "build": "vite build",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss}\"",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "generate:tests": "node ../../scripts/ai-testgen.js",
    "test:emulator": "USE_FIREBASE_EMULATOR=true npm run generate:tests",
    "test:prod": "USE_FIREBASE_EMULATOR=false npm run generate:tests",
    "generate:feature": "bash ../../scripts/generate-feature.sh",
    "dev:e2e": "vite --port 5173",
    "e2e:seed": "npx tsx ../../scripts/seed-e2e-users.ts",
    "e2e": "cross-env NODE_ENV=test playwright test",
    "e2e:ui": "cross-env NODE_ENV=test playwright test --ui",
    "e2e:debug": "cross-env NODE_ENV=test playwright test --debug",
    "e2e:headed": "cross-env NODE_ENV=test playwright test --headed",
    "canary:otp": "npx tsx ../../scripts/canary-verify-otp-template.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:seed:extract": "npx tsx ../../scripts/seed/extract-and-anonymize.ts",
    "devlog": "npx tsx ../../scripts/devlog.ts recent",
    "devlog:errors": "npx tsx ../../scripts/devlog.ts errors",
    "devlog:check": "npx tsx ../../scripts/devlog.ts check",
    "devlog:trace": "npx tsx ../../scripts/devlog.ts trace",
    "validate": "npm run type-check && npm run lint && npm run test:run",
    "validate:full": "npm run type-check && npm run lint && npm run test:run && npm run devlog:check"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "@axync/extract-json": "^1.1.3",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^8.55.2",
    "@sentry/vite-plugin": "^0.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^4.44.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/extension-dropcursor": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
