    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^9.1.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^6.30.3",
    "react-simplikit": "^0.0.39",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
